# Public site origin used in magic links
NEXT_PUBLIC_SITE_URL=https://offerradar.io

# Email alerts: keep disabled until delivery and privacy review are complete
ALERTS_ENABLED=false
ALERT_EMAIL_MODE=resend
RESEND_API_KEY=
ALERT_FROM_EMAIL=OfferRadar Alerts <alerts@example.com>

# Private ops and protected weekly delivery
OPS_ACCESS_KEY=
CRON_SECRET=

# First-party aggregate analytics (server and client must agree)
FIRST_PARTY_ANALYTICS_ENABLED=false
NEXT_PUBLIC_FIRST_PARTY_ANALYTICS_ENABLED=false
